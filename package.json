{
  "name": "metalsmith-seo",
  "version": "1.1.3",
  "description": "A metalsmith plugin for SEO optimization including sitemap generation, meta tags, and more.",
  "keywords": [
    "metalsmith",
    "metalsmith-plugin",
    "seo",
    "sitemap",
    "meta-tags",
    "open-graph"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wernerglinka/metalsmith-seo.git"
  },
  "bugs": {
    "url": "https://github.com/wernerglinka/metalsmith-seo/issues"
  },
  "homepage": "https://github.com/wernerglinka/metalsmith-seo",
  "license": "MIT",
  "author": {
    "name": "Werner Glinka",
    "url": "http://www.wernerglinka.com"
  },
  "contributors": [
    {
      "name": "Werner Glinka",
      "email": "werner@glinka.co"
    }
  ],
  "type": "module",
  "exports": "./src/index.js",
  "files": [
    "src/**/*.js",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "changelog": "auto-changelog -u --commit-limit false --ignore-commit-pattern '^((dev|chore|ci):|Release)'",
    "test": "node --test --test-timeout=15000 'test/**/*.test.js'",
    "coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-timeout=15000 'test/**/*.test.js'",
    "test:coverage": "npm run coverage",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --write .",
    "lint:check": "biome check .",
    "pre-release": "npm run lint:check && npm run format:check && npm test && npx metalsmith-plugin-mcp-server validate .",
    "release:patch": "./scripts/release.sh patch --ci",
    "release:minor": "./scripts/release.sh minor --ci",
    "release:major": "./scripts/release.sh major --ci",
    "release:check": "npm run lint:check && release-it --dry-run",
    "depcheck": "depcheck"
  },
  "dependencies": {
    "cheerio": "^1.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "assert-dir-equal": "^1.1.0",
    "auto-changelog": "^2.5.1",
    "depcheck": "^1.4.7",
    "metalsmith": "^2.7.0",
    "release-it": "^20.0.1"
  },
  "engines": {
    "node": ">= 22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
